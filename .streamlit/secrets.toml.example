# ============================================================
# Streamlit Community Cloud Secrets
# ============================================================
# Copy the KEY=VALUE pairs from your .env file into the
# Streamlit Cloud dashboard under App Settings → Secrets.
#
# This file shows the expected format. Do NOT commit actual secrets.
# On Streamlit Cloud, secrets are injected as environment variables
# and are also accessible via st.secrets["KEY"].
# ============================================================

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key"
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"

STRIPE_SECRET_KEY = "sk_test_your_key"
STRIPE_PUBLISHABLE_KEY = "pk_test_your_key"
STRIPE_WEBHOOK_SECRET = "whsec_your_secret"

APP_NAME = "SportsPlex"
APP_ENV = "production"
APP_URL = "https://your-app-name.streamlit.app"
DEFAULT_TIMEZONE = "America/New_York"
